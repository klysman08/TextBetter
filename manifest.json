{
  "manifest_version": 3,
  "name": "TextBetter",
  "version": "1.0.0",
  "description": "Your premium, Gemini-powered AI writing assistant with Shadcn Zinc styling.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TextBetter Writing Assistant"
  },
  "options_page": "options.html"
}
